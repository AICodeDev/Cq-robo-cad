#pragma once

#include "RB_GYRO_FAST.h"
extern float updateGyro();
#if USE_RB_GYRO_FAST
  extern RB_GYRO_FAST   gyro;
#endif


void ApplyBrake(int ms=500)
{
    

OCR4A = 1023;
OCR4B = 1023;

OCR1A = 1023;
OCR1B = 1023;

delay(ms);

}
void applyMoveBoost(){
      int short_pps_m1 = curr.short_pps.m1;
      int short_pps_m2 = curr.short_pps.m2;

      // -------- Motor 1 --------
      if (short_pps_m1 < PPS_HALT_THRESH &&
          curr.remaining_pulse_m1 > MIN_REMAINING_PULSE)
      {
          curr.halt.m1_halt_count++;
          if (curr.halt.m1_halt_count >= HALT_COUNT_TRIGGER) {
              curr.halt.m1_boost += BOOST_STEP;
              curr.halt.m1_boost = min(curr.halt.m1_boost, BOOST_MAX);
              curr.halt.m1_halt_count = HALT_COUNT_TRIGGER;
          }
      }
      else {
          curr.halt.m1_halt_count = 0;
          curr.halt.m1_boost -= BOOST_DECAY;
          if (curr.halt.m1_boost < 0) curr.halt.m1_boost = 0;
      }

      // -------- Motor 2 --------
      if (short_pps_m2 < PPS_HALT_THRESH &&
          curr.remaining_pulse_m2 > MIN_REMAINING_PULSE)
      {
          curr.halt.m2_halt_count++;
          if (curr.halt.m2_halt_count >= HALT_COUNT_TRIGGER) {
              curr.halt.m2_boost += BOOST_STEP;
              curr.halt.m2_boost = min(curr.halt.m2_boost, BOOST_MAX);
              curr.halt.m2_halt_count = HALT_COUNT_TRIGGER;
          }
      }
      else {
          curr.halt.m2_halt_count = 0;
          curr.halt.m2_boost -= BOOST_DECAY;
          if (curr.halt.m2_boost < 0) curr.halt.m2_boost = 0;
      }


}


void NextMoveV2(long target_pulse, int dir = 1)
{
    resetBoost();
    resetLocalGyro();

    curr.m1_start = curr.total_pulse.m1;
    curr.m2_start = curr.total_pulse.m2;
    curr.target_pulse = abs(target_pulse); // Target is always a distance
    curr.dir = (dir >= 0) ? 1 : -1;        // Store direction: 1 or -1
    curr.type = 1;                         // 1 = straight
    curr.gryo_start = 0;
    
    DEBUG_PRINT("Move Started. Dir: " + String(curr.dir));
}


int UpdateMoveStateV2()
{
    // Calculate distance traveled since NextMove was called
    long t1 = abs(curr.total_pulse.m1 - curr.m1_start);
    long t2 = abs(curr.total_pulse.m2 - curr.m2_start);

    curr.curr_m1_pulse = t1;
    curr.curr_m2_pulse = t2;

    // Distance remaining
    curr.remaining_pulse_m1 = (curr.target_pulse > t1) ? (curr.target_pulse - t1) : 0;
    curr.remaining_pulse_m2 = (curr.target_pulse > t2) ? (curr.target_pulse - t2) : 0;
    
    curr.avg_remaining = (curr.remaining_pulse_m1 + curr.remaining_pulse_m2) * 0.5f;

    // Heading drift logic (t2 - t1)
    // If moving backward, the correction polarity might need to flip 
    // depending on your physical motor orientation
    float dThetaRad = (float)(t2 - t1) / WHEEL_BASE_PULSES;
    curr.heading_encoder = dThetaRad * 57.2957795f;

    curr.gryo_current = updateGyro(); 
    curr.heading_gyro = curr.gryo_current - curr.gryo_start;

    return (curr.avg_remaining > 10 ? 1 : 0); // 10 step tolerance
}







void resetPulse(){
     curr.total_pulse = {0};
   curr.total_pulse.m1 = 0;
   curr.total_pulse.m2 = 0;
    



   
  curr.m1_start = curr.total_pulse.m1;
  curr.m2_start = curr.total_pulse.m2;

 // curr.start_pulse =  curr.total_pulse; //.m1;
  //curr.start_pulse.m2 = curr.total_pulse.m2;

  curr.current_pulse.m1 =0;
  curr.current_pulse.m2 =0;
  curr.current_pulse = {0};
   

}
void NextMove(long target_pulse, int dir=1)
{
  //adjust any error from previus accumulated error of turn or back or forward (mainly turn)
  //based on current heading update the ideal robot pose
  resetBoost();
  //to bre removed;
    
  resetPulse();


  curr.target_pulse = target_pulse; 
  curr.type =1; //1 mean straight
  curr.dir = dir;
  curr.gryo_start =0;
  curr.localTurn = 0.0;
  curr.gryo_start = 0.0;

  resetLocalGyro();

}


void PrintMove(){

    long r1=curr.target_pulse- curr.current_pulse.m1;
    long r2=  curr.target_pulse- curr.current_pulse.m2;
      LOG_INFO3(" Print Move: Rem ",  r1 , r2 );
       
       LOG_INFO3(" FE ",  curr.current_pulse.m1 , curr.current_pulse.m2);
#if USE_RB_GYRO_FAST
        LOG_INFO3(" GYRO ",  curr.heading_gyro , gyro.updateZ() );
#endif


       LOG_INFO3(" FW ", curr.pwm.m1, curr.pwm.m2);
           
       LOG_INFO3(" FS ", curr.short_pps.m1, curr.short_pps.m2 );
       DEBUG_PRINTLN(".");
}

int UpdateMoveState()
{
    //adjust any error from previus accumulated error of turn or back or forward (mainly turn)

    long t1 = curr.total_pulse.m1 - curr.m1_start;
    long t2 = curr.total_pulse.m2 - curr.m2_start;
  //  LOG_INFO3("TT xx",  t1 ,   t2);

    curr.curr_m1_pulse = curr.CurrentM1Count();
    curr.curr_m2_pulse = curr.CurrentM2Count();

    //LOG_INFO3("xx",  curr.curr_m1_pulse ,   curr.curr_m2_pulse);
    

    //DEBUG_PRINTLN("");


    curr.remaining_pulse.m1 = curr.target_pulse - t1;
    curr.remaining_pulse.m2 = curr.target_pulse - t2;
    curr.avg_remaining =
        (curr.remaining_pulse.m1 + curr.remaining_pulse.m2) * 0.5f;

    // --- Encoder-based heading drift (DEG) ---
    float dThetaRad = (float)(t2 - t1) / WHEEL_BASE_PULSES;
    curr.heading_encoder = dThetaRad * 57.2957795f;

#if USE_RB_GYRO == 0
    // --- Gyro-based heading (optional) ---
  //  curr.gryo_current = updateGyro(); // will give drift
 //   curr.heading_gyro = curr.gryo_current - curr.gryo_start;

#endif

#if USE_RB_GYRO_FAST == 1

  if (curr.last_avg_remaining < (curr.avg_remaining -5) 
    || ( curr.last_avg_remaining <  curr.avg_remaining) && (curr.loop_count  % 3 ==0)
   )
  {
    //TODO GYRO
    // --- Gyro-based heading (optional) ---
    curr.gryo_current = gyro.updateZ();// will give drift
    curr.heading_gyro = curr.gryo_current - curr.gryo_start;
    curr.heading_gyro = curr.gryo_current - curr.gryo_start;
    curr.error_tracking.heading_error = curr.heading_gyro;
  }

#endif

    //LOG_INFO3("AVG ",  curr.avg_remaining  ,   -1);
    //DEBUG_PRINTLN("");

    if (curr.avg_remaining <71){
        if (curr.last_avg_remaining != curr.avg_remaining)
          {
              LOG_INFO3("Move : Low Balance: heading_error ",  curr.error_tracking.heading_error  ,  0);
              LOG_INFO3(" remaining_pulse ",  curr.remaining_pulse.m1  ,   curr.remaining_pulse.m2 );              
              DEBUG_PRINT2(" avg_remaining ",  curr.avg_remaining    );
              DEBUG_PRINTLN();
              PrintMove();
          }

    }

    curr.last_avg_remaining= curr.avg_remaining;

    return (curr.avg_remaining > 70 ? 1 : 0); // 70 is tolerance step
}







void movePulse(long target_pulse, int dir=1)
{
  #if USE_RB_GYRO_FAST
    gyro.slowRefresh();
  #endif
  
  //todo Accumulate Error
    NextMove(target_pulse);
    curr.avg_remaining = target_pulse;

    curr.halt.m1_boost=0;
    curr.halt.m2_boost=0;
    curr.halt.m1_halt_count=0;
    curr.halt.m1_halt_count=0;
    
    

    // warm-up
    setMotor1(220);
    setMotor2(220);
    delay(20);

    int startPwm = 295;
    int overSpeedPwm = -1;
    int underSpeedPwm = -1;
    
    #if USE_RB_GYRO_FAST == 1
      startPwm = startPwm+10;
    #endif 


    long START_REDUCING_AT_BALANCE = 450 ;

    if (target_pulse<700){
      START_REDUCING_AT_BALANCE =400;
    }

    
      //start and stablize
    setMotor1(startPwm+5);
    setMotor2(startPwm+5);
    delay(20);  
      
    curr.loop_count=0;
    UpdateMoveState();

    while (UpdateMoveState())
    {
      curr.loop_count++;;
    

      //  printDebugStatus();
        int calcPwm= startPwm + overSpeedPwm - underSpeedPwm;
        // --- Trapezoid profile ---
        int basePWM =
            TrapezoidSpeed(calcPwm ,
                            curr.avg_remaining,
                            START_REDUCING_AT_BALANCE);


        
        applyMoveBoost();
        // --- Heading correction (encoder + gyro) ---
        float headingErr =
            curr.heading_encoder;// + curr.gryo_current; // or fused later

        int corr = HeadingPWMCorrection(headingErr)*6;

        // --- PWM-only adjustment ---
       int pwm1 = basePWM + corr +curr.halt.m1_boost;   // stiff wheel
       int pwm2 = basePWM - corr + curr.halt.m2_boost;          // corrective wheel

       pwm1 = abs(constrain(pwm1, basePWM - 60 , basePWM + 60));
       pwm2 = abs(constrain(pwm2, basePWM - 60, basePWM + 60));

       setMotor1(pwm1);
       setMotor2(pwm2);

      #if DEBUG
       //LOG_INFO3("EC", headingErr, corr);
        if (curr.loop_count % 25 ==0){
           PrintMove();
        }
      #endif
      
      delay(5);
      StopMotors();
      
      #if USE_RB_GYRO_FAST == 1
        delayMicroseconds(200);
      #else
         delay(1);
         delayMicroseconds(200);
      #endif
      
      if ( (curr.short_pps.m1+curr.short_pps.m2) >=1300 ){
          StopMotors();
          delay(1);
          overSpeedPwm = overSpeedPwm-10;

      }
      else{
        overSpeedPwm = 0;
      }
      if ((curr.short_pps.m1 + curr.short_pps.m2) <=200 && curr.avg_remaining<300   ){
        //underspeed Pwm
          underSpeedPwm = underSpeedPwm+10;

      }
      else{
        underSpeedPwm=0;
      }
      if (curr.avg_remaining<300){
        delay(1);
      }
      if (curr.avg_remaining<200){
        delay(1);
      }
       if (curr.avg_remaining<100){
        delay(1);
      }

      if (curr.avg_remaining<50){
        delay(1);
      }




    }

    applyBreak();
    DEBUG_PRINT("After Break.");
    PrintMove();

    delay(50);
    StopMotors();

    // settle + debug
    for (int i = 0; i < 5; i++) {
        delay(50);
#if DEBUG
        //printDebugStatus();
     //   LOG_INFO3(" PWM 1/2", pwm1, pwm2);
       DEBUG_PRINT(i);
       DEBUG_PRINT(".");
       
      PrintMove();
       

#endif
    }
}